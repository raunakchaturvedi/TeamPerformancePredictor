<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TPPProject</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TPPProject.styles.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">TPP Project</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Teams" asp-action="Index">Teams</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Employees" asp-action="Index">Employees</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="BurnoutRisk" asp-action="Index">Burnout Risk</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Performance" asp-action="Index">Performance</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Report" asp-action="Index">Report</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="TeamPerformance" asp-action="Index">Team Predictor</a>
                    </li>

                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container text-center">
            <p>© 2026 - Team Performance Predictor</p>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>