@model List<TPPProject.Models.BurnoutRisk>

<h2 class="mt-3">Burnout Risk Records</h2>

<a href="/BurnoutRisk/Create" class="btn btn-success mb-3">+ Add Burnout Record</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Employee ID</th>
            <th>Working Hours</th>
            <th>Overtime Hours</th>
            <th>Stress Level</th>
            <th>Leave Count</th>
            <th>Risk Level</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.BurnoutRiskId</td>
                <td>@r.Employee?.Name</td>
                <td>@r.WorkingHours</td>
                <td>@r.OvertimeHours</td>
                <td>@r.StressLevel</td>
                <td>@r.LeaveCount</td>
                <td>@r.RiskLevel</td>
            </tr>
        }
    </tbody>
</table>