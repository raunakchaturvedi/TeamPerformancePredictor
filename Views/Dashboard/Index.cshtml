@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mt-3 mb-4">Dashboard</h2>

<div class="row">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Employees</h5>
                <h2>@ViewBag.TotalEmployees</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body">
                <h5 class="card-title">High Burnout Risk</h5>
                <h2>@ViewBag.HighBurnout</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-dark bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">Medium Burnout Risk</h5>
                <h2>@ViewBag.MediumBurnout</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">Low Burnout Risk</h5>
                <h2>@ViewBag.LowBurnout</h2>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-4">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">High Performance</h5>
                <h2>@ViewBag.HighPerformance</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-dark bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">Medium Performance</h5>
                <h2>@ViewBag.MediumPerformance</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-secondary mb-3">
            <div class="card-body">
                <h5 class="card-title">Low Performance</h5>
                <h2>@ViewBag.LowPerformance</h2>
            </div>
        </div>
    </div>
</div>