@model List<TPPProject.Models.Result>

@{
    ViewData["Title"] = "Team Performance Predictor";
}

<h2 class="mt-3 mb-4">Team Performance Predictor</h2>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Team</th>
            <th>Project</th>
            <th>Team Lead</th>
            <th>Total Employees</th>
            <th>High Burnout</th>
            <th>Medium Burnout</th>
            <th>Low Burnout</th>
            <th>High Performance</th>
            <th>Medium Performance</th>
            <th>Low Performance</th>
            <th>Team Score</th>
            <th>Prediction</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var team in Model)
        {
            <tr>
                <td>@team.TeamName</td>
                <td>@team.ProjectName</td>
                <td>@team.TeamLead</td>
                <td>@team.TotalEmployees</td>
                <td>@team.HighBurnoutCount</td>
                <td>@team.MediumBurnoutCount</td>
                <td>@team.LowBurnoutCount</td>
                <td>@team.HighPerformanceCount</td>
                <td>@team.MediumPerformanceCount</td>
                <td>@team.LowPerformanceCount</td>
                <td>@team.TeamScore</td>
                <td>
                    @if (team.TeamPerformanceLevel == "High")
                    {
                        <span class="badge bg-success">High</span>
                    }
                    else if (team.TeamPerformanceLevel == "Medium")
                    {
                        <span class="badge bg-warning text-dark">Medium</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Low</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>