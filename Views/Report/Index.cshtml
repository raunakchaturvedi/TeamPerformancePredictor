@model List<TPPProject.Models.Employee>

@{
    ViewData["Title"] = "Report";
}

<h2 class="mt-3 mb-4">Employee Report</h2>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Employee Name</th>
            <th>Department</th>
            <th>Team</th>
            <th>Burnout Risk</th>
            <th>Performance Level</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var emp in Model)
        {
            var burnout = emp.BurnoutRisks?.FirstOrDefault(b => b.EmployeeId != null);
            var performance = emp.Performances?.FirstOrDefault(p => p.EmployeeId != null);

            <tr>
                <td>@emp.Name</td>
                <td>@emp.Department</td>
                <td>@(emp.Team?.TeamName ?? "No Team")</td>
                <td>@(burnout?.RiskLevel ?? "No Data")</td>
                <td>@(performance?.PerformanceLevel ?? "No Data")</td>
            </tr>
        }
    </tbody>
</table>