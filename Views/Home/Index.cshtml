@{
    ViewData["Title"] = "Home";
}

<div class="text-center mt-4 mb-5">
    <h1 class="display-4 fw-bold">Team Performance Predictor</h1>
    <p class="lead">
        Employee Management and Analysis System using ASP.NET Core MVC
    </p>
</div>

<div class="row g-4">

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <h4 class="card-title">Employees</h4>
                <p class="card-text">Manage employee details like name and department.</p>
                <a href="/Employees" class="btn btn-primary">Go to Employees</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <h4 class="card-title">Burnout Risk</h4>
                <p class="card-text">Analyze employee burnout risk based on workload and stress.</p>
                <a href="/BurnoutRisk" class="btn btn-danger">Go to Burnout Risk</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <h4 class="card-title">Performance</h4>
                <p class="card-text">Track tasks, deadlines, productivity, and teamwork score.</p>
                <a href="/Performance" class="btn btn-success">Go to Performance</a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <h4 class="card-title">Dashboard</h4>
                <p class="card-text">View overall project statistics and summary insights.</p>
                <a href="/Dashboard" class="btn btn-warning">Go to Dashboard</a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <h4 class="card-title">Report</h4>
                <p class="card-text">See combined employee, burnout, and performance report.</p>
                <a href="/Report" class="btn btn-dark">Go to Report</a>
            </div>
        </div>
    </div>

</div>