@model List<TPPProject.Models.Performance>

@{
    ViewData["Title"] = "Performance";
}

<h2 class="mt-3">Performance Records</h2>

<a href="/Performance/Create" class="btn btn-success mb-3">+ Add Performance Record</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Employee</th>
            <th>Tasks Completed</th>
            <th>Deadlines Met</th>
            <th>Productivity Score</th>
            <th>Teamwork Score</th>
            <th>Performance Level</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.PerformanceId</td>
                <td>@(p.Employee?.Name ?? "No Employee")</td>
                <td>@p.TasksCompleted</td>
                <td>@p.DeadlinesMet</td>
                <td>@p.ProductivityScore</td>
                <td>@p.TeamworkScore</td>
                <td>@p.PerformanceLevel</td>
            </tr>
        }
    </tbody>
</table>