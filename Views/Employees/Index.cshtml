@model List<TPPProject.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<h2 class="mt-3">Employees</h2>

<a href="/Employees/Create" class="btn btn-success mb-3">+ Add Employee</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Department</th>
            <th>Team</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var e in Model)
        {
            <tr>
                <td>@e.EmployeeId</td>
                <td>@e.Name</td>
                <td>@e.Department</td>
                <td>@(e.Team?.TeamName ?? "No Team")</td>
                <td>
                    <a href="/Employees/Edit/@e.EmployeeId" class="btn btn-warning btn-sm me-2">Edit</a>
                    <a href="/Employees/Delete/@e.EmployeeId"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Delete this employee?')">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>