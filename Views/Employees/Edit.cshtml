@model TPPProject.Models.Employee

@{
    ViewData["Title"] = "Edit Employee";
}

<h2 class="mt-3">Edit Employee</h2>

<form method="post" action="/Employees/Edit" class="mt-3">
    <input type="hidden" name="EmployeeId" value="@Model.EmployeeId" />

    <div class="mb-3">
        <label class="form-label">Name</label>
        <input type="text" name="Name" value="@Model.Name" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Department</label>
        <select name="Department" class="form-control" required>
            <option value="">-- Select Department --</option>
            @foreach (var dept in ViewBag.Departments)
            {
                if (dept == Model.Department)
                {
                    <option value="@dept" selected>@dept</option>
                }
                else
                {
                    <option value="@dept">@dept</option>
                }
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Team</label>
        <select name="TeamId" class="form-control" required>
            <option value="">-- Select Team --</option>
            @foreach (var team in ViewBag.Teams)
            {
                if (team.TeamId == Model.TeamId)
                {
                    <option value="@team.TeamId" selected>@team.TeamName</option>
                }
                else
                {
                    <option value="@team.TeamId">@team.TeamName</option>
                }
            }
        </select>
    </div>

    <button type="submit" class="btn btn-warning">Update</button>
    <a href="/Employees" class="btn btn-secondary">Back</a>
</form>