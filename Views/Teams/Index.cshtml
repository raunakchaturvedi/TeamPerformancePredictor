@model List<TPPProject.Models.Team>

@{
    ViewData["Title"] = "Teams";
}

<h2 class="mt-3">Teams</h2>

<a href="/Teams/Create" class="btn btn-success mb-3">+ Add Team</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Team ID</th>
            <th>Team Name</th>
            <th>Project Name</th>
            <th>Team Lead</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.TeamId</td>
                <td>@t.TeamName</td>
                <td>@t.ProjectName</td>
                <td>@t.TeamLead</td>
                <td>
                    <a href="/Teams/Edit/@t.TeamId" class="btn btn-warning btn-sm me-2">Edit</a>
                    <a href="/Teams/Delete/@t.TeamId"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Delete this team?')">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>