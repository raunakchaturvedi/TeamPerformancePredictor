@model TPPProject.Models.Team

@{
    ViewData["Title"] = "Edit Team";
}

<h2 class="mt-3">Edit Team</h2>

<form method="post" action="/Teams/Edit" class="mt-3">
    <input type="hidden" name="TeamId" value="@Model.TeamId" />

    <div class="mb-3">
        <label class="form-label">Team Name</label>
        <input type="text" name="TeamName" value="@Model.TeamName" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Project Name</label>
        <input type="text" name="ProjectName" value="@Model.ProjectName" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Team Lead</label>
        <input type="text" name="TeamLead" value="@Model.TeamLead" class="form-control" required />
    </div>

    <button type="submit" class="btn btn-warning">Update</button>
    <a href="/Teams" class="btn btn-secondary">Back</a>
</form>